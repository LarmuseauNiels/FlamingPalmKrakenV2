# Discord Bot Configuration
TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id
GUILD_ID=your_guild_id
OAUTHSECRET=your_discord_oauth_client_secret
CALLBACK_URL=https://yourdomain.com/login

# Database
DATABASE_URL=mysql://user:password@host:3306/database_name

# External Services
BUGSNAG_API_KEY=your_bugsnag_api_key
OPENAI_API_KEY=your_openai_api_key

# JWT (use a separate secret, not the bot token)
JWT_SECRET=your_jwt_secret

# Deployment
CAPROVER_GIT_COMMIT_SHA=local

# Feature Flags
# DISABLE=true  # Uncomment to prevent bot from starting

# Discord Channel IDs
LOG_CHANNEL_ID=your_log_channel_id
UPDATE_CHANNEL_ID=your_update_channel_id
LFG_CHANNEL_ID=your_lfg_channel_id
VINTAGE_STORY_CHANNEL_ID=your_vintage_story_channel_id
AFK_CHANNEL_ID=your_afk_channel_id
ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id
PURCHASES_CHANNEL_ID=your_purchases_channel_id
PARTY_FORUM_CHANNEL_ID=your_party_forum_channel_id
DAILY_LOGIN_CHANNEL_ID=your_daily_login_channel_id
MEMES_CHANNEL=your_memes_channel_id

# Discord User IDs
BOT_OWNER_ID=your_bot_owner_user_id
